PORT=5000
MONGO_URI=mongodb://localhost:27017/crime_detection_system
JWT_SECRET=your_jwt_secret_here
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_MONITOR_INTERVAL_MS=60000
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password
FRONTEND_URL=http://localhost:5173

# Twilio Verify (optional — SMS phone verification in Settings)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_VERIFY_SERVICE_SID=

# Twilio SMS alerts (optional — SMS when investigator is assigned a case)
TWILIO_PHONE_NUMBER=
# Or use a Messaging Service instead of TWILIO_PHONE_NUMBER:
# TWILIO_MESSAGING_SERVICE_SID=
